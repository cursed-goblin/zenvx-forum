# ---- Supabase via Cloudflare proxy ----
# IMPORTANT: This is the Cloudflare Worker proxy URL, NOT the raw *.supabase.co URL.
# All client + server Supabase API calls route through this domain for DDoS protection.
PUBLIC_SUPABASE_PROXY_URL=https://api.zenvx.com

# Public anon key (safe to expose to the browser; RLS is the security boundary)
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Realtime endpoint (WebSocket cannot be HTTP-proxied; point at Supabase directly)
PUBLIC_SUPABASE_REALTIME_URL=wss://your-project-ref.supabase.co/realtime/v1

# ---- Server-only secrets (NEVER expose to the client/bundle) ----
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
